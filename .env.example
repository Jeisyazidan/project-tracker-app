# Used by `docker compose up` — copy to .env and fill in real values.
# Never commit the real .env file (already covered by .gitignore).

# PostgreSQL
DB_NAME=project_tracker
DB_USER=postgres
DB_PASSWORD=change_this_to_a_strong_password

# JWT / cookies
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d
COOKIE_SECRET=change_this_too
NODE_ENV=production

# URLs — must match how the app is actually reached
FRONTEND_ORIGIN=http://localhost
APP_BASE_URL=http://localhost
APP_PORT=80

# SMTP (reminder emails)
SMTP_HOST=
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@company.internal

# Reminder cron timezone
REMINDER_TIMEZONE=Asia/Jakarta

# Fonnte WhatsApp API (optional — leave blank to disable WhatsApp notifications)
FONNTE_TOKEN=
